{
  "fallbackScreenId": "unknown",
  "rules": [
    {
      "id": "not_logged_in",
      "match": {
        "loggedIn": false
      },
      "screenId": "login",
      "notes": "Auth gates everything else."
    },
    {
      "id": "network_denied",
      "match": {
        "loggedIn": true,
        "permissions": {
          "network": "denied"
        }
      },
      "screenId": "permissions_network",
      "notes": "Without network permission the app cannot detect devices or rooms on the LAN."
    },
    {
      "id": "network_unset",
      "match": {
        "loggedIn": true,
        "permissions": {
          "network": "unset"
        }
      },
      "screenId": "permissions_network",
      "notes": "While permission is unset, the simulator skips this rule, resolves the next match, and shows an allow/deny modal on that screen. Denied still uses the full-page permissions_network screen."
    },
    {
      "id": "wifi_off",
      "match": {
        "loggedIn": true,
        "wifiConnected": false
      },
      "screenId": "no_wifi",
      "notes": "Wi‑Fi is required for this flow; Ethernet alone does not satisfy the app’s connectivity check."
    },
    {
      "id": "bluetooth_denied",
      "match": {
        "loggedIn": true,
        "permissions": {
          "bluetooth": "denied"
        }
      },
      "screenId": "permissions_bluetooth"
    },
    {
      "id": "camera_denied",
      "match": {
        "loggedIn": true,
        "permissions": {
          "camera": "denied"
        }
      },
      "screenId": "permissions_camera"
    },
    {
      "id": "devices_offline_zero_app_rooms",
      "match": {
        "loggedIn": true,
        "appRoomCount": 0,
        "permissions": {
          "network": "granted"
        },
        "devices": [
          {
            "status": "offline"
          }
        ]
      },
      "screenId": "room_setup",
      "notes": "0 app rooms: setup path even when the first device is offline."
    },
    {
      "id": "devices_offline_or_unassigned",
      "match": {
        "loggedIn": true,
        "permissions": {
          "network": "granted"
        },
        "devices": [
          {
            "status": "offline"
          }
        ]
      },
      "screenId": "devices_need_attention",
      "notes": "LAN device reachability is unknown without network permission."
    },
    {
      "id": "devices_found_pick_unassigned",
      "match": {
        "loggedIn": true,
        "wifiConnected": true,
        "appRoomCount": 0,
        "permissions": {
          "network": "granted",
          "bluetooth": "granted",
          "camera": "granted"
        },
        "devices": [
          {
            "status": "unassigned"
          }
        ]
      },
      "screenId": "no_rooms_network_devices",
      "notes": "0 app rooms + LAN devices: empty room list / create room (Figma room view empty list)."
    },
    {
      "id": "devices_unassigned_zero_app_rooms",
      "match": {
        "loggedIn": true,
        "appRoomCount": 0,
        "permissions": {
          "network": "granted"
        },
        "devices": [
          {
            "status": "unassigned"
          }
        ]
      },
      "screenId": "no_rooms_network_devices",
      "notes": "0 app rooms + unassigned on LAN: empty list + devices (same as devices_found_pick_unassigned when BT/camera not required)."
    },
    {
      "id": "devices_unassigned",
      "match": {
        "loggedIn": true,
        "permissions": {
          "network": "granted"
        },
        "devices": [
          {
            "status": "unassigned"
          }
        ]
      },
      "screenId": "devices_need_attention",
      "notes": "Discovering unassigned devices on the network requires network permission."
    },
    {
      "id": "single_room",
      "match": {
        "loggedIn": true,
        "wifiConnected": true,
        "appRoomCount": 1
      },
      "screenId": "room_interior"
    },
    {
      "id": "multiple_rooms",
      "match": {
        "loggedIn": true,
        "wifiConnected": true,
        "appRoomCount": 2
      },
      "screenId": "room_interior"
    },
    {
